{
  "name": "saturn",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "author": "Divya Swaroop Jaiswal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/saturn"
  },
  "build": {
    "appId": "com.saturn.app",
    "productName": "Saturn",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "electronLanguages": ["en"],
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "!**/*.map",
      "!**/*.md",
      "!**/*.ts",
      "!src/**/*",
      "!node_modules/**/*",
      "!**/devtools_resources.pak",
      "!**/version",
      "!**/*.pdb"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "fileAssociations": [
      {
        "ext": "asm",
        "name": "Simplex Assembly File",
        "role": "Editor"
      },
      {
        "ext": "o",
        "name": "Simplex Object File",
        "role": "Editor"
      }
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "export": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "lucide-react": "^0.539.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "vite": "^7.3.1"
  }
}
